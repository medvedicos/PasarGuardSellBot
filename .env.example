BOT_TOKEN=your_bot_token_here            # ваш BotFather токен

PANEL_URL=https://your-panel.example.com   # адрес панели PasarGuard (без trailing slash)
PANEL_ADMIN_USERNAME=admin                 # админ логин PasarGuard
PANEL_ADMIN_PASSWORD=password              # админ пароль PasarGuard
SUBS_LINK_TEMPLATE=https://your-panel.example.com/sub/{username}   # шаблон ссылки подписки

# Настройка прокси/инбаундов PasarGuard (опционально)
PANEL_PROXY_TYPE=vless
PANEL_INBOUND_TAG=VLESS TCP REALITY
PANEL_PROXY_FLOW=xtls-rprx-vision

# optional
HOST=0.0.0.0
PORT=8443
